# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/church_app_db
# For replica-set (required for transactions):
# MONGODB_URI=mongodb://localhost:27017/church_app_db?replicaSet=rs0
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/church_app_db

# JWT
JWT_ACCESS_SECRET=change_me_to_a_secure_random_string_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_another_secure_random_string_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Church App <noreply@churchapp.com>"

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Storage (local | s3)
STORAGE_DRIVER=local

# AWS S3 (if STORAGE_DRIVER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# YouTube
YOUTUBE_API_KEY=
